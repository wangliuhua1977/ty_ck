<Window x:Class="Ty.Ck.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Ty.Ck.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="ty_ck"
        Width="1480"
        Height="920"
        MinWidth="1280"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Margin="18"
                Background="{StaticResource ShellBackgroundBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="264" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="28,0,0,28">
                    <DockPanel Margin="22">
                        <Border DockPanel.Dock="Bottom"
                                Style="{StaticResource CardBorderStyle}"
                                Margin="0,24,0,0"
                                Padding="18,16">
                            <StackPanel>
                                <TextBlock Text="第 1 轮"
                                           Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="项目骨架与基础壳子"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <StackPanel>
                            <Grid Margin="0,4,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="48"
                                        Height="48"
                                        Background="{StaticResource AccentSubtleBrush}"
                                        BorderBrush="{StaticResource AccentStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="巡"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,2,0,0">
                                    <TextBlock Text="ty_ck"
                                               FontSize="22"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,2,0,0"
                                               Text="桌面巡检系统"
                                               Style="{StaticResource SecondaryTextStyle}" />
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding NavigationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,8"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource NavigationButtonStyle}"
                                                ToolTip="{Binding Title}"
                                                AutomationProperties.AutomationId="{Binding AutomationId}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Glyph}"
                                                           Style="{StaticResource GlyphTextStyle}" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="12,0,0,0"
                                                           Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="1" Margin="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       Style="{StaticResource PageTitleTextStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding CurrentPageDescription}"
                                       Style="{StaticResource SecondaryTextStyle}" />
                        </StackPanel>

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Style="{StaticResource TagBorderStyle}">
                            <TextBlock Text="{Binding CurrentDateText}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Style="{StaticResource ContentHostBorderStyle}">
                        <ContentControl Content="{Binding CurrentPage}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
