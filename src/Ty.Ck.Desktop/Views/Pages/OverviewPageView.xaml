<UserControl x:Class="Ty.Ck.Desktop.Views.Pages.OverviewPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <WrapPanel Margin="0,0,0,16">
                <Border Style="{StaticResource TagBorderStyle}" Margin="0,0,10,0">
                    <TextBlock Text="全部目录" />
                </Border>
                <Border Style="{StaticResource TagBorderStyle}" Margin="0,0,10,0">
                    <TextBlock Text="今日截图" />
                </Border>
                <Border Style="{StaticResource TagBorderStyle}">
                    <TextBlock Text="异常优先" />
                </Border>
            </WrapPanel>

            <UniformGrid Columns="4">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="北门通道" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:18 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="办公楼外场" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:21 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="围界东侧" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:24 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="停车区入口" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:27 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="厂区转角" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:30 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="装卸口" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:33 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="外墙南段" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:36 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Border Height="120" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16" />
                        <TextBlock Margin="0,14,0,0" Text="办公楼门厅" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0" Text="09:40 截图占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
