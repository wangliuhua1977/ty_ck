<UserControl x:Class="Ty.Ck.Desktop.Views.Pages.ReviewPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="待复核列表" Style="{StaticResource SectionTitleTextStyle}" />
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Padding="16" Background="{StaticResource AccentSubtleBrush}" BorderBrush="{StaticResource AccentStrokeBrush}" BorderThickness="1" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="南区 1 号门摄像机" FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0" Text="完全无法正常播放" Style="{StaticResource SecondaryTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,10,0,0" Padding="16" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="厂区东侧球机" FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0" Text="画面不稳定" Style="{StaticResource SecondaryTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,10,0,0" Padding="16" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="办公楼西侧枪机" FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0" Text="待人工判定" Style="{StaticResource SecondaryTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="视频区域占位" Style="{StaticResource SectionTitleTextStyle}" />
                    <Border Grid.Row="1"
                            Margin="0,18,0,18"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" Text="视频画面" FontSize="30" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0" Text="RTSP 播放留待后续轮次接入" Style="{StaticResource SecondaryTextStyle}" />
                        </StackPanel>
                    </Border>
                    <UniformGrid Grid.Row="2" Columns="3">
                        <Border Height="90" Margin="0,0,10,0" Background="{StaticResource SurfaceAltBrush}" CornerRadius="14" />
                        <Border Height="90" Margin="0,0,10,0" Background="{StaticResource SurfaceAltBrush}" CornerRadius="14" />
                        <Border Height="90" Background="{StaticResource SurfaceAltBrush}" CornerRadius="14" />
                    </UniformGrid>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="2">
                <Button Content="重试" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,10,0" />
                <Button Content="截图" Style="{StaticResource SecondaryActionButtonStyle}" />
            </WrapPanel>
        </Grid>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="点位信息" Style="{StaticResource SectionTitleTextStyle}" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="点位名称" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="1" Text="南区 1 号门摄像机" />
                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="平台状态" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="辅助信息占位" />
                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="最近告警" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="列表留待后续接入" />
                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="结论" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="以画面稳定性为准" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="操作区" Style="{StaticResource SectionTitleTextStyle}" />
                        <UniformGrid Margin="0,18,0,0" Rows="2" Columns="2">
                            <Button Content="正常" Style="{StaticResource PrimaryActionButtonStyle}" Margin="0,0,10,10" />
                            <Button Content="故障" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,0,10" />
                            <Button Content="通知" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,10,0" />
                            <Button Content="下一条" Style="{StaticResource SecondaryActionButtonStyle}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
