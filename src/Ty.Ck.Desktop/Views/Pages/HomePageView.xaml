<UserControl x:Class="Ty.Ck.Desktop.Views.Pages.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <UniformGrid Rows="1" Columns="4">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="今日巡检任务" Style="{StaticResource OverlineTextStyle}" />
                        <TextBlock Margin="0,10,0,0" Text="24" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Margin="0,8,0,0" Text="排班与执行占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="待复核" Style="{StaticResource OverlineTextStyle}" />
                        <TextBlock Margin="0,10,0,0" Text="08" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Margin="0,8,0,0" Text="待人工判定" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="通知记录" Style="{StaticResource OverlineTextStyle}" />
                        <TextBlock Margin="0,10,0,0" Text="15" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Margin="0,8,0,0" Text="今日发送占位" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="平台同步" Style="{StaticResource OverlineTextStyle}" />
                        <TextBlock Margin="0,10,0,0" Text="待接入" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Margin="0,8,0,0" Text="本轮不实现" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="任务概览" Style="{StaticResource SectionTitleTextStyle}" />
                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="日常巡检批次" />
                            <Border Grid.Column="1" Style="{StaticResource TagBorderStyle}">
                                <TextBlock Text="09:00 / 14:00 / 19:00" />
                            </Border>

                            <TextBlock Grid.Row="1" Margin="0,16,0,0" Text="异常复核队列" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="16,16,0,0" Text="3 组待处理" Style="{StaticResource SecondaryTextStyle}" />

                            <TextBlock Grid.Row="2" Margin="0,16,0,0" Text="通知策略" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="16,16,0,0" Text="自动 / 审核后通知占位" Style="{StaticResource SecondaryTextStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="目录状态" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Margin="0,18,0,0"
                                Padding="16"
                                Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="一级目录 A" />
                                <TextBlock Grid.Column="1" Text="42 点位" />
                            </Grid>
                        </Border>
                        <Border Margin="0,12,0,0"
                                Padding="16"
                                Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="一级目录 B" />
                                <TextBlock Grid.Column="1" Text="35 点位" />
                            </Grid>
                        </Border>
                        <Border Margin="0,12,0,0"
                                Padding="16"
                                Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="一级目录 C" />
                                <TextBlock Grid.Column="1" Text="18 点位" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="近期复核" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,18,0,0" Text="南区 1 号门摄像机" />
                        <TextBlock Margin="0,6,0,0" Text="视频异常待确认" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,14,0,0" Text="厂区东侧球机" />
                        <TextBlock Margin="0,6,0,0" Text="待人工结论" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="最近通知" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,18,0,0" Text="维护人 @ 发送占位" />
                        <TextBlock Margin="0,6,0,0" Text="海报与记录留待后续轮次接入" Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
