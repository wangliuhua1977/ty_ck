<UserControl x:Class="Ty.Ck.Desktop.Views.Pages.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="平台基础接入配置" Style="{StaticResource SectionTitleTextStyle}" />
                        <Button Grid.Column="1"
                                Command="{Binding LoadConfigurationCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="刷新配置" />
                    </Grid>
                    <TextBlock Margin="0,12,0,0"
                               Text="当前轮只验证统一网关、token 缓存与 version=1.1 解密链路，不联动业务页面。"
                               TextWrapping="Wrap"
                               Style="{StaticResource SecondaryTextStyle}" />
                    <TextBox Margin="0,16,0,0"
                             MinHeight="160"
                             Padding="12"
                             IsReadOnly="True"
                             Text="{Binding ConfigurationSummary, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="定向验证入口" Style="{StaticResource SectionTitleTextStyle}" />
                    <WrapPanel Margin="0,18,0,0">
                        <Button Margin="0,0,12,12"
                                Command="{Binding RunCryptoDiagnosticCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="验证加解密链路" />
                        <Button Margin="0,0,12,12"
                                Command="{Binding RunTokenCacheDiagnosticCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="验证 Token 缓存" />
                        <Button Margin="0,0,12,12"
                                Command="{Binding VerifyAccessTokenCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="调用 getAccessToken" />
                    </WrapPanel>

                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Padding="12,8"
                                 Text="{Binding DeviceCode, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Command="{Binding VerifyDeviceInfoCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="调用 getDeviceInfoByDeviceCode" />
                    </Grid>
                    <TextBlock Margin="0,10,0,0"
                               Text="deviceCode 仅用于定向验证主详情接口；未配置 enterpriseUser 时该按钮会直接返回配置提示。"
                               TextWrapping="Wrap"
                               Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="当前缓存状态" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBox Margin="0,16,0,0"
                                 MinHeight="180"
                                 Padding="12"
                                 IsReadOnly="True"
                                 Text="{Binding CurrentCacheSummary, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="最近一次执行结果" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBox Margin="0,16,0,0"
                                 MinHeight="280"
                                 Padding="12"
                                 IsReadOnly="True"
                                 Text="{Binding OperationOutput, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
