<UserControl x:Class="Ty.Ck.Desktop.Views.Pages.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <UniformGrid Margin="20" Columns="2">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="平台接入" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,18,0,0" Text="地址、鉴权、加解密配置留待后续轮次接入" TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="巡检策略" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,18,0,0" Text="时间窗、启用策略、跳过规则留待后续轮次接入" TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="通知设置" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,18,0,0" Text="自动通知、人工审核后通知留待后续轮次接入" TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="数据维护" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,18,0,0" Text="CSV 导入导出与人工字段维护留待后续轮次接入" TextWrapping="Wrap" Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </ScrollViewer>
</UserControl>
