<UserControl x:Class="Ty.Ck.Desktop.Views.Pages.DeviceLedgerPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="设备列表" Style="{StaticResource SectionTitleTextStyle}" />
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Padding="16" Background="{StaticResource AccentSubtleBrush}" BorderBrush="{StaticResource AccentStrokeBrush}" BorderThickness="1" CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="南区 1 号门摄像机" />
                                <TextBlock Grid.Column="1" Text="目录 A" />
                                <TextBlock Grid.Column="2" Text="已选中" Foreground="{StaticResource AccentBrush}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,10,0,0" Padding="16" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="厂区东侧球机" />
                                <TextBlock Grid.Column="1" Text="目录 B" />
                                <TextBlock Grid.Column="2" Text="启用" Style="{StaticResource SecondaryTextStyle}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,10,0,0" Padding="16" Background="{StaticResource SurfaceAltBrush}" CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="办公楼西侧枪机" />
                                <TextBlock Grid.Column="1" Text="目录 C" />
                                <TextBlock Grid.Column="2" Text="停巡" Foreground="{StaticResource WarningBrush}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="设备详情" Style="{StaticResource SectionTitleTextStyle}" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="点位名称" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="1" Text="南区 1 号门摄像机" />
                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="平台编码" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="待接入" />
                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="所属目录" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="目录 A" />
                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="维护负责人" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="张三" />
                            <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="经纬度" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Text="平台同步后展示" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="人工字段" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,18,0,0" Text="CSV 导入导出留待后续轮次接入" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
